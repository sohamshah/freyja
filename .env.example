# Freyja — API keys for LLM providers
# Copy this to .env and fill in the keys you want to use.

# Anthropic (Claude) — primary provider
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — for GPT models
OPENAI_API_KEY=sk-...

# Cerebras — for fast inference (GLM 4.7)
CEREBRAS_API_KEY=csk-...

# Fireworks — for GLM5 / other open models
FIREWORKS_API_KEY=fw_...

# Optional: override the default permission tier
# Options: none, low, medium, high, yolo
# FREYJA_PERMISSION_TIER=yolo
