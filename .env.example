# Freyja local environment
# Copy to .env and fill in only the providers/services you use.
# .env and .env.* are ignored by git; this example is safe to commit.

# Model providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
CEREBRAS_API_KEY=
FIREWORKS_API_KEY=

# Web/search tooling
PARALLEL_API_KEY=

# Optional/experimental providers or local service integrations
GROQ_API_KEY=
GROK_API_KEY=
XAI_API_KEY=
DATABASE_URL=

# Optional Anthropic profile keys for local auth experiments
ANTHROPIC_API_KEY_DEV=
ANTHROPIC_API_KEY_STAGING=
ANTHROPIC_API_KEY_PROD=
ANTHROPIC_API_KEY_DEMO=

# Optional EMA service endpoints used by some local workflows
EMA_ENV_NAME=
EMA_DEV_BEARER_TOKEN=
EMA_GRPC_HOST=
EMA_GRPC_PORT=
EMA_WFE_GRPC_HOST=
EMA_WFE_GRPC_PORT=
EMA_DATAINGEST_GRPC_HOST=
EMA_DATAINGEST_GRPC_PORT=

# Freyja bridge defaults
FREYJA_WORKSPACE=
FREYJA_MODEL=claude-sonnet-4-6
FREYJA_DEBUG_LOG=1
FREYJA_PERMISSION_AUTO=low
FREYJA_COMPUTER_ENABLED=0
FREYJA_PYTHON=

# Optional subagent/runtime tuning
FREYJA_SUBAGENT_MAX_ITERATIONS=
FREYJA_AGENT_MAX_ITERATIONS_EXPLORE=
FREYJA_AGENT_MAX_ITERATIONS_CODE=
FREYJA_AGENT_MAX_ITERATIONS_REVIEW=
FREYJA_AGENT_MAX_ITERATIONS_TEST=

# Optional visual capture/debug paths
FREYJA_FRAME_DUMP=0
FREYJA_FRAME_DUMP_DIR=
FREYJA_SCREENSHOT=
FREYJA_SCREENSHOT_DELAY=5000
FREYJA_SCREENSHOT_BURST=0
FREYJA_SCREENSHOT_PROMPT=
FREYJA_VIBRANCY=

# Optional native input/capture overrides
FREYJA_CAPTURE_URL=
FREYJA_INPUT_URL=
AGENT_HARNESS_CAPTURE_URL=

# Development server override
VITE_DEV_SERVER_URL=http://localhost:5179
